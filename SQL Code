    SELECT 4 UNION ALL
    SELECT 5 UNION ALL
    SELECT 6
),

future_cutoffs AS (
    SELECT
        t.ORDERID,
        t.SHIPMENTID,
        DATEADD(day, d.day_offset, t.ORDERCREATEDON::DATE) AS cutoff_date,
        wc.cutoff_time,
        TO_TIMESTAMP_NTZ(
            TO_CHAR(DATEADD(day, d.day_offset, t.ORDERCREATEDON::DATE), 'YYYY-MM-DD') || ' ' || wc.cutoff_time
        ) AS cutoff_timestamp
    FROM today_cutoff t
    CROSS JOIN day_offsets_future d
    LEFT JOIN weekly_cutoffs wc
        ON t.carrier = wc.carrier
       AND CASE DAYOFWEEK(DATEADD(day, d.day_offset, t.ORDERCREATEDON::DATE))
            WHEN 0 THEN 'SUNDAY'
            WHEN 1 THEN 'MONDAY'
            WHEN 2 THEN 'TUESDAY'
            WHEN 3 THEN 'WEDNESDAY'
            WHEN 4 THEN 'THURSDAY'
            WHEN 5 THEN 'FRIDAY'
            WHEN 6 THEN 'SATURDAY'
         END = wc.weekday
    LEFT JOIN PUBLIC_HOLIDAYS_NRW ph
        ON ph.holiday_date = DATEADD(day, d.day_offset, t.ORDERCREATEDON::DATE)
    WHERE wc.cutoff_time IS NOT NULL
    AND TO_TIMESTAMP_NTZ(
            TO_CHAR(DATEADD(day, d.day_offset, t.ORDERCREATEDON::DATE), 'YYYY-MM-DD') || ' ' || wc.cutoff_time
          ) > t.ORDERCREATEDON
    AND ph.holiday_date IS NULL  -- exclude holidays
),

past_cutoffs AS (
    SELECT
        t.ORDERID,
        t.SHIPMENTID,
        DATEADD(day, -d.day_offset, t.ORDERCREATEDON::DATE) AS cutoff_date,
        wc.cutoff_time,
        TO_TIMESTAMP_NTZ(
            TO_CHAR(DATEADD(day, -d.day_offset, t.ORDERCREATEDON::DATE), 'YYYY-MM-DD') || ' ' || wc.cutoff_time
        ) AS cutoff_timestamp
    FROM today_cutoff t
    CROSS JOIN day_offsets_past d
    LEFT JOIN weekly_cutoffs wc
        ON t.carrier = wc.carrier
       AND CASE DAYOFWEEK(DATEADD(day, -d.day_offset, t.ORDERCREATEDON::DATE))
            WHEN 0 THEN 'SUNDAY'
            WHEN 1 THEN 'MONDAY'
            WHEN 2 THEN 'TUESDAY'
            WHEN 3 THEN 'WEDNESDAY'
            WHEN 4 THEN 'THURSDAY'
            WHEN 5 THEN 'FRIDAY'
            WHEN 6 THEN 'SATURDAY'
         END = wc.weekday
    LEFT JOIN PUBLIC_HOLIDAYS_NRW ph
        ON ph.holiday_date = DATEADD(day, -d.day_offset, t.ORDERCREATEDON::DATE)
    WHERE wc.cutoff_time IS NOT NULL
    AND TO_TIMESTAMP_NTZ(
            TO_CHAR(DATEADD(day, -d.day_offset, t.ORDERCREATEDON::DATE), 'YYYY-MM-DD') || ' ' || wc.cutoff_time
          ) <= t.ORDERCREATEDON
    AND ph.holiday_date IS NULL  -- exclude holidays
),

next_cutoff_ranked AS (
    SELECT *,
        ROW_NUMBER() OVER (
            PARTITION BY ORDERID
            ORDER BY cutoff_timestamp ASC
        ) AS rn
    FROM future_cutoffs
),

last_cutoff_ranked AS (
    SELECT *,
        ROW_NUMBER() OVER (
            PARTITION BY ORDERID
            ORDER BY cutoff_timestamp DESC
        ) AS rn
    FROM past_cutoffs
),

all_final_cutoffs AS (

SELECT
    t.ORDERID,
    t.ORDERCREATEDON,
    t.Name_Shipping_Method,
    t.SHIPMENTID,
    t.carrier,
    t.today_cutoff,
    -- last cutoff before order
    TO_TIMESTAMP_NTZ(
        TO_CHAR(l.cutoff_date, 'YYYY-MM-DD') || ' ' || l.cutoff_time
    ) AS last_cutoff,
    -- next cutoff after order
    TO_TIMESTAMP_NTZ(
        TO_CHAR(n.cutoff_date, 'YYYY-MM-DD') || ' ' || n.cutoff_time
    ) AS next_cutoff
FROM today_cutoff t
LEFT JOIN last_cutoff_ranked l
    ON t.ORDERID = l.ORDERID AND l.rn = 1
LEFT JOIN next_cutoff_ranked n
    ON t.ORDERID = n.ORDERID AND n.rn = 1

 ), 
 Count_Orders_bw_cutoffs  AS (
SELECT
    ORDERID,
    ORDERCREATEDON,
    Name_Shipping_Method,
    SHIPMENTID,
    carrier,
    today_cutoff,
    last_cutoff,
    next_cutoff,

    COUNT(DISTINCT CASE
        WHEN ORDERCREATEDON BETWEEN DATEADD(hour, -24, next_cutoff)
                               AND next_cutoff
        THEN ORDERID
    END) OVER (
        PARTITION BY carrier, next_cutoff
    ) AS orders_last_24h,

    COUNT(DISTINCT CASE
        WHEN ORDERCREATEDON BETWEEN DATEADD(hour, -4, next_cutoff)
                               AND next_cutoff
        THEN ORDERID
    END) OVER (
        PARTITION BY carrier, next_cutoff
    ) AS orders_last_4h,

    COUNT(DISTINCT CASE
        WHEN ORDERCREATEDON BETWEEN DATEADD(hour, -2, next_cutoff)
                               AND next_cutoff
        THEN ORDERID
    END) OVER (
        PARTITION BY carrier, next_cutoff
    ) AS orders_last_2h,

    COUNT(DISTINCT CASE
        WHEN ORDERCREATEDON >= last_cutoff
         AND ORDERCREATEDON < next_cutoff
        THEN ORDERID
    END) OVER (
        PARTITION BY carrier, next_cutoff
    ) AS orders_between_cutoffs

FROM all_final_cutoffs
ORDER BY carrier, today_cutoff
), 

Checking_85_and_95_Amount AS (

Select 
    ORDERID,
    SHIPMENTID,
    ORDERCREATEDON,
    Name_Shipping_Method,
    carrier,
    today_cutoff,
    last_cutoff,
    next_cutoff,
    orders_last_24h,
    orders_last_4h,
    orders_last_2h,
    orders_between_cutoffs,

    CASE
    WHEN ORDERCREATEDON BETWEEN DATEADD(hour, -4, next_cutoff) AND next_cutoff AND (orders_last_4h/NULLIF(orders_between_cutoffs, 0)) > 0.20
    THEN FALSE
    ELSE TRUE
    END AS "Below 20% Order Volume Rule (4h)",

    CASE
    WHEN ORDERCREATEDON BETWEEN DATEADD(hour, -2, next_cutoff) AND next_cutoff AND (orders_last_2h/NULLIF(orders_between_cutoffs, 0)) > 0.10
    THEN FALSE
    ELSE TRUE
    END AS "Below 10% Order Volume Rule (2h)",


From Count_Orders_bw_cutoffs
Order by  ORDERCREATEDON
)

/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//Combining the number of orders before and between the carrier specific cuttoffs table and the SLA Check table for each order
/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////



Select
"Order Id",
"External_Order_Number",
"CLIENTNAME", 
"CreatedOn",
slach."SHIPMENTID",
slach."Name_Shipping_Method",
"ReadyToShipDate",
"FirstDeliveryOn",
"weekday",
"month", 
"sent on time (order reception)", 
"First Shipment", 
"Wrong Packing Slip", 
"Below 85% Order Volume Rule (4h)",
"Below 95% Order Volume Rule (2h)",
orders_last_2h,
orders_last_4h,
orders_between_cutoffs,

From SLA_Check_each_Order slach
Left Join Checking_85_and_95_Amount cha89 on slach."Order Id" = cha89.ORDERID and slach."SHIPMENTID" = cha89.SHIPMENTID,
Order by "CLIENTNAME","CreatedOn";
