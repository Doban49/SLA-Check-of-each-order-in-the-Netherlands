 NEXT_WORKING_DAY AS (
        -- Anchor member: start with CreatedOn + 1
        SELECT 
            o."Id" AS order_id,
            o."CreatedOn",
            DATEADD(day, 1, DATE(o."CreatedOn")) AS candidate_date,
            o."ClientId"
        FROM Database."Order" o
        WHERE o."ClientId" = :clientid
          AND o."CreatedOn" = :daterange

        UNION ALL

        -- Recursive member: increment candidate_date by 1 until it's a working day
        SELECT 
            nwd.order_id,
            nwd."CreatedOn",
            DATEADD(day, 1, nwd.candidate_date),
            nwd."ClientId"
        FROM NEXT_WORKING_DAY nwd
        LEFT JOIN PUBLIC_HOLIDAYS_NRW ph ON nwd.candidate_date = ph.holiday_date
        WHERE 
            DAYOFWEEK(nwd.candidate_date) IN (6, 0)  -- 1=Sunday, 7=Saturday, aber falsch, es ist es  0=Sunday und 6=Samstag
            OR ph.holiday_date IS NOT NULL
    ),
-- Final selection: choose the first candidate_date that's a working day


Next_Working_Day_Final AS (
SELECT 
    order_id,
    "CreatedOn",
    MIN(candidate_date) AS next_working_day
FROM NEXT_WORKING_DAY nwd
LEFT JOIN PUBLIC_HOLIDAYS_NRW ph ON nwd.candidate_date = ph.holiday_date
WHERE DAYOFWEEK(nwd.candidate_date) NOT IN (6, 0)
  AND ph.holiday_date IS NULL
GROUP BY order_id, "CreatedOn"
), 

