weekly_cutoffs AS (
    SELECT * FROM VALUES
        ('BPOST',       'MONDAY',    TIME 'XX:XX'),
        ('BPOST',       'TUESDAY',   TIME 'XX:XX'),
        ('BPOST',       'WEDNESDAY', TIME 'XX:XX'),
