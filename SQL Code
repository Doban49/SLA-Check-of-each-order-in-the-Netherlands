        ('UPS',       'MONDAY',    TIME 'XX:XX'),
        ('UPS',       'TUESDAY',   TIME 'XX:XX'),
        ('UPS',       'WEDNESDAY', TIME 'XX:XX'),
        ('UPS',       'THURSDAY',  TIME 'XX:XX'),
        ('UPS',       'FRIDAY',    TIME 'XX:XX'),

        ('GLS',         'MONDAY',    TIME 'XX:XX'),
        ('GLS',         'TUESDAY',   TIME 'XX:XX'),
        ('GLS',         'WEDNESDAY', TIME 'XX:XX'),
        ('GLS',         'THURSDAY',  TIME 'XX:XX'),
        ('GLS',         'FRIDAY',    TIME 'XX:XX'),

        ('LA POSTE',    'MONDAY',    TIME 'XX:XX'),
        ('LA POSTE',    'TUESDAY',   TIME 'XX:XX'),
        ('LA POSTE',    'WEDNESDAY', TIME 'XX:XX'),
        ('LA POSTE',    'THURSDAY',  TIME 'XX:XX'),
        ('LA POSTE',    'FRIDAY',    TIME 'XX:XX')
    AS t(carrier, weekday, cutoff_time)
),

orders_carrier AS (
    SELECT
        sh.ORDERID,
        sh.ORDERCREATEDON,
        sh.Name_Shipping_Method,
        sh.SHIPMENTID,
        REGEXP_SUBSTR(
            sh.Name_Shipping_Method,
            '(BPOST|GLS|UPS|COLIS PRIVE|LA POSTE|CORREOS|NETHERLANDS DHL|GERMANY DHL)'
        ) AS carrier
    FROM Database."Shipment" sh
    WHERE sh.ORDERCREATEDON::DATE = :daterange
      AND sh.CLIENTID = :clientid
),

orders_with_day AS (
    SELECT
        *,
        CASE DAYOFWEEK(ORDERCREATEDON)
            WHEN 0 THEN 'SUNDAY'
            WHEN 1 THEN 'MONDAY'
            WHEN 2 THEN 'TUESDAY'
            WHEN 3 THEN 'WEDNESDAY'
            WHEN 4 THEN 'THURSDAY'
            WHEN 5 THEN 'FRIDAY'
            WHEN 6 THEN 'SATURDAY'
        END AS weekday_name
    FROM orders_carrier
),

today_cutoff AS (
    SELECT
        o.*,
        wc.cutoff_time,
        CASE
            WHEN wc.cutoff_time IS NOT NULL THEN
                TO_TIMESTAMP_NTZ(
                    TO_CHAR(o.ORDERCREATEDON::DATE, 'YYYY-MM-DD') || ' ' || wc.cutoff_time
                )
        END AS today_cutoff
    FROM orders_with_day o
    LEFT JOIN weekly_cutoffs wc
        ON o.carrier = wc.carrier
       AND o.weekday_name = wc.weekday
),

